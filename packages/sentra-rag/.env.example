# PostgreSQL with pgvector (same DB as intelligenceboard)
DATABASE_URL=postgresql://user:password@localhost:5432/sentra_db

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
SENTRA_GEN_MODEL=gemma2:9b
SENTRA_EMBED_MODEL=nomic-embed-text

# Path to medical PDF library
MEDICAL_LIBRARY_PATH=../../library/medical

# Optional: Vertex RAG fallback (leave empty to disable)
VERTEX_RAG_CORPUS_ID=
GOOGLE_PROJECT_ID=sentra-healthcare-solution
GOOGLE_LOCATION=us-central1
