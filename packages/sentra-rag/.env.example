# Sentra RAG — Local-First PDF Ingestion Pipeline
# Salin ke .env dan isi nilai yang sesuai

# ============================================
# DATABASE (PostgreSQL + pgvector)
# Same DB as intelligenceboard
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/sentra_db

# ============================================
# OLLAMA (Local Embedding + Generation)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
SENTRA_GEN_MODEL=gemma2:9b
SENTRA_EMBED_MODEL=nomic-embed-text

# ============================================
# PDF LIBRARY PATH
# ============================================
MEDICAL_LIBRARY_PATH=../../library/medical

# ============================================
# GCP / VERTEX AI (optional — Vertex RAG fallback)
# Auth: Application Default Credentials
# Role required: Vertex AI User (roles/aiplatform.user)
# ============================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json
GCP_PROJECT_ID=tenacious-crane-494419-j5
GCP_LOCATION=us-central1

# ============================================
# VERTEX RAG CORPUS (leave empty to disable)
# ============================================
VERTEX_RAG_CORPUS_ID=
