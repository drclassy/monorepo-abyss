{
  "name": "@the-abyss/sentra-rag",
  "version": "0.1.0",
  "private": true,
  "description": "Sentra RAG Engine — Local-first medical knowledge retrieval with pgvector + Ollama",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .turbo node_modules dist",
    "status": "npx tsx src/status.ts",
    "ingest": "npx tsx src/ingestion/pipeline.ts",
    "ingest:pha": "npx tsx src/ingestion/pipeline.ts --pha",
    "ingest:gen": "npx tsx src/ingestion/pipeline.ts --gen",
    "ingest:pdf": "npx tsx src/cli/ingest-pdf.ts",
    "registry:update": "npx tsx src/cli/registry-update.ts",
    "registry:list": "npx tsx src/cli/registry-update.ts list",
    "embed:approved": "npx tsx src/cli/embed-approved.ts",
    "eval:retrieval": "npx tsx src/cli/eval-retrieval.ts",
    "query": "npx tsx src/query.ts"
  },
  "dependencies": {
    "@the-abyss/document-ingestion": "workspace:*",
    "@the-abyss/vector-store": "workspace:*",
    "dotenv": "^16.4.5",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@the-abyss/config-eslint": "workspace:*",
    "@the-abyss/config-typescript": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "sentra:tier": "crown-jewel"
}
