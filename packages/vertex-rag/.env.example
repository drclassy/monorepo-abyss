# Sentra Vertex RAG Configuration
# Salin ke .env dan isi nilai yang sesuai

# ============================================
# GCP / VERTEX AI
# Auth: Service Account key (JANGAN commit file JSON ini)
# Role required: Vertex AI User (roles/aiplatform.user)
# ============================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json
GCP_PROJECT_ID=abyss-monorepo
GCP_LOCATION=us-central1

# ============================================
# VERTEX RAG CORPUS
# ============================================
VERTEX_RAG_CORPUS_ID=your-corpus-id
NOTEBOOK_CORPUS_ID=your-notebook-corpus-id

# ============================================
# AI MODEL
# ============================================
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# VERTEX SEARCH (Discovery Engine)
# ============================================
VERTEX_SEARCH_DATASTORE_ID=medical-knowledge-base
