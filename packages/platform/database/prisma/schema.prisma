generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANCY & ORGANIZATION
// ============================================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  apps        App[]
  users       UserOrganization[]
  auditLogs   AuditLog[]

  @@index([slug])
}

model App {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  config         Json?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  apiKeys        ApiKey[]
  aiSessions     AiSession[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  name          String?
  avatar        String?
  emailVerified DateTime?
  passwordHash  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  organizations UserOrganization[]
  sessions      Session[]
  accounts      Account[]

  @@index([email])
}

model UserOrganization {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ============================================
// AUTHENTICATION (NextAuth.js Compatible)
// ============================================

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// API KEY MANAGEMENT
// ============================================

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  permissions String[] @default([])
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([appId])
  @@index([key])
}

// ============================================
// AI SESSION TRACKING
// ============================================

model AiSession {
  id           String   @id @default(uuid())
  appId        String
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  agentName    String
  flowId       String?
  flowVersion  String?
  handoffUrl   String?
  status       AiSessionStatus @default(PENDING)
  input        Json?
  output       Json?
  logs         String?  @db.Text
  metrics      Json?    // { latency, tokenUsage, model, confidence }
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  auditLogs    AuditLog[]

  @@index([appId])
  @@index([status])
  @@index([createdAt])
  @@index([agentName])
}

enum AiSessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// AUDIT TRAIL (Compliance Audit)
// ============================================

model AuditLog {
  id             String     @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  aiSessionId    String?
  aiSession      AiSession?    @relation(fields: [aiSessionId], references: [id], onDelete: SetNull)
  action         String
  resource       String
  resourceId     String?
  userId         String?
  userEmail      String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime   @default(now())

  @@index([organizationId])
  @@index([aiSessionId])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

// ============================================
// LANGFLOW REGISTRY
// ============================================

model FlowDefinition {
  id          String   @id @default(uuid())
  name        String
  version     String
  flowId      String   @unique // Langflow internal ID
  description String?
  jsonPath    String
  isActive    Boolean  @default(false)
  metadata    Json?    // { models, inputs, outputs }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  executions  FlowExecution[]

  @@unique([name, version])
  @@index([isActive])
}

model FlowExecution {
  id           String   @id @default(uuid())
  flowDefId    String
  flowDef      FlowDefinition @relation(fields: [flowDefId], references: [id], onDelete: Cascade)
  status       FlowExecutionStatus @default(PENDING)
  input        Json?
  output       Json?
  latency      Int?     // milliseconds
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([flowDefId])
  @@index([status])
  @@index([createdAt])
}

enum FlowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SHADOW // Shadow mode execution
}

// ============================================
// SAGA EXECUTION TRACKING (Orchestrator)
// ============================================

model SagaExecution {
  id            String   @id @default(cuid())
  flowId        String
  sagaType      String   // "diagnosis-flow" | "referral-flow" | "generic-flow"
  status        SagaExecutionStatus @default(RUNNING)
  input         Json
  output        Json?
  error         String?
  steps         Json     // Array of { name, status, startedAt, completedAt, output?, error? }
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  organizationId String?
  
  @@index([flowId])
  @@index([status])
  @@index([startedAt])
  @@index([organizationId])
}

enum SagaExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
  COMPENSATED
}

// ============================================
// KNOWLEDGE BASE (RAG & Vector Search)
// ============================================

model KnowledgeBase {
  id        String   @id @default(uuid())
  content   String   @db.Text
  embedding Unsupported("vector(768)")? 
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id])
}
