{
  "name": "@the-abyss/unicom-agent-sdk",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-unicom-launcher": "./dist/bin/codex-unicom-launcher.js",
    "claude-code-unicom-launcher": "./dist/bin/claude-code-unicom-launcher.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin/codex-unicom-launcher.ts src/bin/claude-code-unicom-launcher.ts --format esm --dts --clean",
    "codex-unicom-launcher": "node dist/bin/codex-unicom-launcher.js",
    "claude-code-unicom-launcher": "node dist/bin/claude-code-unicom-launcher.js",
    "test": "vitest run src/__tests__",
    "test:watch": "vitest src/__tests__",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@the-abyss/unicom-core": "workspace:*"
  },
  "devDependencies": {
    "@the-abyss/config-eslint": "workspace:*",
    "@the-abyss/config-typescript": "workspace:*",
    "@the-abyss/unicom-testkit": "workspace:*",
    "@types/node": "^22.19.19",
    "tsup": "^8.5.1",
    "vitest": "^2.1.0"
  },
  "sentra:tier": "private-product"
}
