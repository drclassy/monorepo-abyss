{
  "name": "@the-abyss/unicom-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts src/dev.ts --format esm --dts --clean",
    "dev": "tsx src/dev.ts",
    "test": "vitest run src/__tests__",
    "test:watch": "vitest src/__tests__",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@the-abyss/unicom-core": "workspace:*",
    "@the-abyss/unicom-policy": "workspace:*",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@the-abyss/config-eslint": "workspace:*",
    "@the-abyss/config-typescript": "workspace:*",
    "@the-abyss/unicom-testkit": "workspace:*",
    "@types/node": "^22.19.19",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^2.1.0"
  },
  "sentra:tier": "private-product"
}
