# Sub-Task 4.3: Orchestrator Gateway API

## ARCHITECTURE RULE
ALL applications (Referralink, Simulator, Sentratorium) MUST execute flows via:
`POST /flows/:flowId/run` → Orchestrator → Langflow → aiSession log → return

## BOOTSTRAP

```bash
pnpm create-app orchestrator --template nestjs
cd apps/orchestrator
pnpm add @nestjs/common @nestjs/core @nestjs/websockets socket.io \
  @the-abyss/langflow-client @the-abyss/database \
  @the-abyss/ai-core class-validator class-transformer \
  @opentelemetry/api @opentelemetry/sdk-node
```

## FLOWS CONTROLLER — `src/flows/flows.controller.ts`

```typescript
import { Controller, Post, Get, Body, Param, Query } from '@nestjs/common';
import { FlowsService } from './flows.service';
import { FlowExecutionDto } from './dto/flow-execution.dto';

@Controller('flows')
export class FlowsController {
  constructor(private flowsService: FlowsService) {}

  @Post(':flowId/run')
  async executeFlow(
    @Param('flowId') flowId: string,
    @Body() dto: FlowExecutionDto,
  ) {
    return await this.flowsService.executeFlow({
      flowId,
      input: dto.input,
      sessionId: dto.sessionId,
      organizationId: dto.organizationId,
      shadowMode: dto.shadowMode || false,
    });
  }

  @Get('health')
  async health() {
    const langflowHealthy = await this.flowsService.checkLangflow();
    const databaseHealthy = await this.flowsService.checkDatabase();
    return {
      status: langflowHealthy && databaseHealthy ? 'healthy' : 'degraded',
      langflow: langflowHealthy,
      database: databaseHealthy,
      timestamp: new Date(),
    };
  }

  @Get('metrics')
  async metrics() {
    const lastHour = new Date(Date.now() - 3600000);
    return await this.flowsService.getMetrics(lastHour);
  }
}
```

## FLOWS SERVICE — `src/flows/flows.service.ts`

```typescript
import { Injectable } from '@nestjs/common';
import { LangflowClient } from '@the-abyss/langflow-client';
import { prisma, createAuditLog } from '@the-abyss/database';

@Injectable()
export class FlowsService {
  constructor(private langflowClient: LangflowClient) {}

  async executeFlow(params: {
    flowId: string;
    input: Record<string, unknown>;
    sessionId?: string;
    organizationId: string;
    shadowMode?: boolean;
  }) {
    const startTime = Date.now();
    const sessionId = params.sessionId || `sess_${Date.now()}`;

    try {
      // 1. Cost limit check — MANDATORY
      const costAllowed = await this.costLimiter.checkCostLimit(params.organizationId);
      if (!costAllowed) throw new Error('COST_LIMIT_EXCEEDED');

      // 2. Get flow metadata
      const flowMetadata = await this.getFlowMetadata(params.flowId);

      // 3. Execute flow
      const result = await this.langflowClient.executeFlow({
        flowId: params.flowId,
        input: params.input,
      });

      const latencyMs = Date.now() - startTime;
      const costUsd = this.calculateCost(flowMetadata, result.tokensUsed);

      // 4. Log to Sentratorium — ALWAYS
      await prisma.aiSession.create({
        data: {
          sessionId,
          organizationId: params.organizationId,
          agentType: 'flow-executor',
          domain: flowMetadata.domain,
          inputPrompt: JSON.stringify(params.input),
          modelUsed: flowMetadata.modelUsed || 'langflow',
          tokenUsed: result.tokensUsed || 0,
          latencyMs,
          output: JSON.stringify(result.output),
          costUsd,
          metadata: { flowId: params.flowId, shadowMode: params.shadowMode || false },
        },
      });

      // 5. HIPAA audit log — healthcare domain only
      if (flowMetadata.domain === 'healthcare') {
        await createAuditLog({
          organizationId: params.organizationId,
          action: 'executed_flow',
          resource: 'Flow',
          resourceId: params.flowId,
          metadata: { sessionId, latencyMs, success: true },
        });
      }

      return { sessionId, output: result.output, latencyMs, costUsd, tokensUsed: result.tokensUsed };

    } catch (error) {
      // Error path — STILL log to Sentratorium
      await prisma.aiSession.create({
        data: {
          sessionId,
          organizationId: params.organizationId,
          agentType: 'flow-executor',
          domain: 'unknown',
          inputPrompt: JSON.stringify(params.input),
          modelUsed: 'langflow',
          tokenUsed: 0,
          latencyMs: Date.now() - startTime,
          output: JSON.stringify({ error: error.message }),
          metadata: { flowId: params.flowId, error: true },
        },
      });
      throw error;
    }
  }

  private calculateCost(flowMetadata: any, tokensUsed: number): number {
    const pricing: Record<string, number> = {
      'gpt-4': 0.00003,
      'claude-3.5-sonnet': 0.00003,
      'ollama': 0,
    };
    return tokensUsed * (pricing[flowMetadata.modelUsed] || 0.00003);
  }
}
```

