## REAL-TIME FEED — WebSocket hook pattern

```typescript
// src/components/flows/RealTimeExecutionFeed.tsx
import { useWebSocket } from '@/hooks/useWebSocket';

export function RealTimeExecutionFeed() {
  const [executions, setExecutions] = useState<any[]>([]);
  const { data } = useWebSocket('/api/flows/ws/executions');

  useEffect(() => {
    if (data) setExecutions(prev => [data, ...prev].slice(0, 50));
  }, [data]);

  // Table: flowId | status | latency | cost | timestamp
}
```

## DASHBOARD SLAs
- Load time: < 3 seconds
- WebSocket latency: < 5 seconds
- Available filters: date range, flow ID, domain, status
- Model comparison table updated: every 1 hour

