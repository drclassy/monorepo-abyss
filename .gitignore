# ---- LOCAL KNOWLEDGE BASES & PHI / CLINICAL DATA ----
# Raw medical documents are processed locally by Vertex pipelines.
# They must never be tracked in Git.
repository/medical-raw/
# DICOM, HL7, FHIR export dumps — always PHI
*.dicom
*.dcm
*.hl7
*.hl7v2
*.fhir.json
# Clinical data directories — runtime only, never commit
data/phi/
data/patient/
data/clinical-raw/
data/clinical/
fixtures/phi/
tests/fixtures/phi/
# Large dataset/training files — use DVC or cloud storage
*.parquet
*.jsonl
# ML training data dumps — never commit raw patient-derived data
training-data/
dataset/
datasets/

# ---- AI / ML MODEL WEIGHTS (never commit — use model registry or DVC) ----
# PyTorch
*.pt
*.pth
*.bin
# ONNX
*.onnx
# Hugging Face / Safetensors
*.safetensors
# Keras / TF
*.h5
*.hdf5
*.keras
# scikit-learn / general
*.pkl
*.pickle
*.joblib
# NumPy arrays
*.npy
*.npz
# Model directories
models/weights/
models/checkpoints/
checkpoints/
*.ckpt
# LLM quantised / GGUF local models
*.gguf
*.ggml
*.bin.gz

