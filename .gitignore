.agent/reports/digest/
.agent/reports/portal-verify-status.json
.agent/reports/*.json
.agent/reports/*.log

# ---- CROWN JEWEL — packages/sentra ----
# Source code is tracked. These runtime / derived artifacts must not be pushed.
packages/sentra/**/dist/
packages/sentra/**/*.tsbuildinfo
packages/sentra/**/coverage/
# If any sentra package embeds local model weights or PHI fixtures, block them:
packages/sentra/**/models/
packages/sentra/**/data/phi/
packages/sentra/**/fixtures/phi/

