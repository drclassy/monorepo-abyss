#              are TRACKED BY DESIGN. See load-bearing negations at the end.
# ========================================

# ---- SECRETS & ENV (NEVER COMMIT) ----
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
