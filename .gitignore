# ---- AGENT OPERATIONAL SSOT ----
# .agent/ is protected operational state, not cache or junk.
# Track the curated SSOT. Only generated local helper output stays ignored.
.agent/reports/ssot-suggestions/
.agent/reports/digest/
.agent/reports/portal-verify-status.json
.agent/reports/*.json
.agent/reports/*.log

# ---- CROWN JEWEL — packages/sentra ----
# Proprietary clinical AI engines — excluded from public push, local dev only.
packages/sentra/

# ---- APPS — ALL PRIVATE, NOT FOR PUBLIC PUSH ----
# All applications are excluded from this public platform monorepo.
# Each app lives in its own private repo.
apps/

# ---- EXPLICIT EXEMPTIONS (TRACKED BY DESIGN) ----
# Load-bearing negations — DO NOT REMOVE.
# Git evaluates .gitignore top-down; trailing negations override earlier rules.
# KEPT: core `.agent/` governance memory + `CLAUDE.md` (Claude Code project instructions)
!.agent/
!.agent/**
!pnpm-lock.yaml

# KEPT: Cursor project rules, subagents, hooks — team parity (cursor.com/docs)
!.cursor/README.md
!.cursor/index.mdc
!.cursor/hooks.json
!.cursor/sandbox.json
!.cursor/rules/
!.cursor/rules/**
!.cursor/agents/
!.cursor/agents/**
!.cursor/hooks/
!.cursor/hooks/after-edit.mjs
!.cursor/hooks/autofix-loop.mjs
.cursor/hooks/edit-log.txt
.cursor/hooks/session-log.txt

gha-creds-*.json

