# Environment Variables for The Abyss

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://abyss:abyss_dev_password@localhost:5432/abyss_db?schema=public"

# ============================================
# LANGFLOW
# ============================================
LANGFLOW_API_URL="http://localhost:7860"
LANGFLOW_API_KEY=""

# ============================================
# AI PROVIDERS
# ============================================
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# APPLICATION
# ============================================
NODE_ENV="development"
PORT="3000"
APP_NAME="the-abyss"

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ============================================
# TURBOREPO
# ============================================
TURBO_TOKEN=""
TURBO_TEAM=""

# ============================================
# SENTRY (Optional)
# ============================================
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ============================================
# RESPAN (LLM Observability)
# Get key at: https://platform.respan.ai/platform/api/api-keys
# ============================================
RESPAN_API_KEY=""

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_SHADOW_MODE="true"
ENABLE_AI_CONSENSUS="false"
ENABLE_RAG="false"

# ============================================
# VECTOR STORE (packages/vector-store)
# Embedding model served locally via Ollama
# Dimensions must match KnowledgeBase schema: vector(768)
# ============================================
VECTOR_STORE_EMBEDDING_MODEL="nomic-embed-text"
VECTOR_STORE_EMBEDDING_DIMENSIONS="768"
