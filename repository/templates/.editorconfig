# ──────────────────────────────────────────────────────────────
# Sentra Healthcare AI — Standard .editorconfig Template
# Enforces consistent editor behavior across all IDEs.
# Pairs with .gitattributes for LF enforcement.
# ──────────────────────────────────────────────────────────────

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{ps1,bat,cmd}]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
