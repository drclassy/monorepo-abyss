{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/tooling/governance/agent/hooks/session-start.ps1\"",
            "statusMessage": "Checking required session context",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/tooling/governance/agent/hooks/pre-tool-use.ps1\"",
            "statusMessage": "Checking repository command policy",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/tooling/governance/agent/hooks/post-tool-use.ps1\"",
            "statusMessage": "Logging file edit",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/tooling/governance/agent/hooks/session-stop.ps1\"",
            "statusMessage": "Recording session stop",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\drclassy\\.codex\\scripts\\verify-auto.ps1\"",
            "statusMessage": "Running global Codex verification",
            "timeout": 900
          }
        ]
      }
    ]
  }
}
