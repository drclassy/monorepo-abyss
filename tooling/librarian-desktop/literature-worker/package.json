{
  "name": "@the-abyss/literature-worker",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"for (const dir of ['.turbo','node_modules','dist']) { require('node:fs').rmSync(dir, { recursive: true, force: true }); }\""
  },
  "dependencies": {
    "@the-abyss/literature-harvester": "workspace:*"
  },
  "devDependencies": {
    "@the-abyss/config-eslint": "workspace:*",
    "@the-abyss/config-typescript": "workspace:*",
    "@types/node": "22.19.18",
    "tsx": "4.21.0",
    "vitest": "2.1.9"
  }
}
