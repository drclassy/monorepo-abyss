{
  "name": "classy-handbook-launcher",
  "displayName": "Classy Handbook Launcher",
  "description": "Status bar launcher for Classy handbook documents",
  "version": "0.2.0",
  "publisher": "sentra-local",
  "icon": "codex.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.mjs",
    "package": "node esbuild.mjs && vsce package --no-dependencies",
    "vscode:prepublish": "node esbuild.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "classyHandbook.openPalette",
        "title": "Classy Handbook: Open Palette"
      }
    ]
  }
}
