{
  "name": "@the-abyss/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "abyss": "./dist/index.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.6.2",
    "ora": "^8.0.0",
    "prompts": "^2.4.2",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "22.19.18",
    "@types/fs-extra": "11.0.4",
    "@types/prompts": "2.4.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "@the-abyss/config-typescript": "workspace:*",
    "@the-abyss/config-eslint": "workspace:*"
  }
}
