{
  "openapi": "3.0.0",
  "info": {
    "title": "Prompt Transformer API",
    "description": "Enterprise-grade prompt optimization and evaluation engine for Sentra Abyss.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://ctev2.sentra.ai/api",
      "description": "Production server"
    }
  ],
  "paths": {
    "/transform": {
      "post": {
        "summary": "Optimize a prompt",
        "description": "Transforms a raw idea into a structured Super Prompt optimized for a specific LLM and task type.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OptimizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful optimization",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OptimizeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/evaluate": {
      "post": {
        "summary": "Evaluate prompt quality",
        "description": "Analyzes a prompt across 4 dimensions (Structure, Clarity, Completeness, Specificity) and provides actionable feedback.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EvaluateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful evaluation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EvaluateResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Quota exceeded"
          }
        }
      }
    },
    "/prompts": {
      "get": {
        "summary": "List prompts",
        "description": "Retrieves a paginated list of prompts from the user's library.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "taskType", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of prompts"
          }
        }
      },
      "post": {
        "summary": "Save prompt",
        "description": "Saves a new prompt record to the library.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePrompt"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Prompt saved"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OptimizeRequest": {
        "type": "object",
        "required": ["rawIdea"],
        "properties": {
          "rawIdea": { "type": "string", "description": "The unstructured idea to optimize" },
          "taskType": { "$ref": "#/components/schemas/TaskType" },
          "tone": { "$ref": "#/components/schemas/PromptTone" },
          "format": { "$ref": "#/components/schemas/OutputFormat" },
          "targetLlm": { "$ref": "#/components/schemas/LLMProvider" },
          "templateSlug": { "type": "string" }
        }
      },
      "OptimizeResponse": {
        "type": "object",
        "properties": {
          "superPrompt": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "task": { "type": "string" },
              "context": { "type": "string" },
              "chainOfThought": { "type": "string" },
              "constraints": { "type": "array", "items": { "type": "string" } },
              "formatSpec": { "type": "string" },
              "fullPrompt": { "type": "string" }
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "latencyMs": { "type": "integer" },
              "model": { "type": "string" }
            }
          }
        }
      },
      "EvaluateRequest": {
        "type": "object",
        "required": ["promptText"],
        "properties": {
          "promptText": { "type": "string" },
          "provider": { "$ref": "#/components/schemas/LLMProvider" }
        }
      },
      "EvaluateResponse": {
        "type": "object",
        "properties": {
          "overallScore": { "type": "number", "minimum": 0, "maximum": 10 },
          "dimensions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": { "type": "string" },
                "score": { "type": "number" },
                "feedback": { "type": "string" }
              }
            }
          },
          "suggestions": { "type": "array", "items": { "type": "string" } }
        }
      },
      "CreatePrompt": {
        "type": "object",
        "required": ["rawInput", "optimizedText"],
        "properties": {
          "rawInput": { "type": "string" },
          "optimizedText": { "type": "string" },
          "taskType": { "$ref": "#/components/schemas/TaskType" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "TaskType": {
        "type": "string",
        "enum": ["CODING", "EMAIL", "ANALYSIS", "CREATIVE", "RESEARCH", "BUSINESS", "EDUCATION", "MARKETING", "GENERAL"]
      },
      "PromptTone": {
        "type": "string",
        "enum": ["PROFESSIONAL", "CASUAL", "TECHNICAL", "ACADEMIC", "CREATIVE", "PERSUASIVE"]
      },
      "OutputFormat": {
        "type": "string",
        "enum": ["DETAILED", "CONCISE", "STRUCTURED", "STEP_BY_STEP", "CONVERSATIONAL"]
      },
      "LLMProvider": {
        "type": "string",
        "enum": ["CLAUDE", "OPENAI", "MISTRAL", "GEMINI", "QWEN", "GROK", "LOCAL"]
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
