{
  "name": "@the-abyss/classy-transformer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm run db:generate && next build",
    "dev": "next dev --port 3003",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "node -e \"process.env.DATABASE_URL ||= 'postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder?schema=public'; process.env.DIRECT_URL ||= process.env.DATABASE_URL; const { spawnSync } = require('node:child_process'); const result = spawnSync(process.execPath, ['./node_modules/prisma/build/index.js', 'generate'], { stdio: 'inherit', env: process.env }); process.exit(result.status ?? 1);\"",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:resolve:init": "prisma migrate resolve --applied 20260322000000_init",
    "db:migrate:apply": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-prisma-migrations.ps1",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hookform/resolvers": "^3.9.0",
    "@mistralai/mistralai": "^1.5.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "6.5.0",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@respan/instrumentation-anthropic": "^1.1.2",
    "@respan/instrumentation-openai": "^1.0.2",
    "@respan/respan": "^2.1.0",
    "@sentra/design-token": "workspace:*",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/analytics": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "geist": "^1.7.0",
    "lucide-react": "^0.454.0",
    "next": "15.2.6",
    "next-themes": "^0.4.6",
    "openai": "^4.85.0",
    "pg": "^8.20.0",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.60.0",
    "resend": "^6.9.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.2.1",
    "globals": "^17.4.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5",
    "prisma": "6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  }
}
