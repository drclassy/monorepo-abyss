# Classy Transformer Engine V2 — Environment Variables

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/cte_v2"
DIRECT_URL="postgresql://postgres:password@localhost:5432/cte_v2"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# LLM Providers (server-side, users can also store their own keys)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
MISTRAL_API_KEY=""
GOOGLE_AI_API_KEY=""
QWEN_API_KEY=""
XAI_API_KEY=""

# Encryption (for user API keys stored in DB)
ENCRYPTION_KEY="generate-a-32-byte-hex-key-here"

# Email (Resend — https://resend.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Classy <noreply@classy.com>"
EMAIL_QUEUE_CRON_SECRET="set-a-strong-random-secret-for-cron-processing"
SUBSCRIPTION_EXPIRY_CRON_SECRET="set-a-strong-random-secret-for-expiry-processing"

# Observability
NEXT_PUBLIC_SENTRY_DSN=""
RESPAN_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3003"
