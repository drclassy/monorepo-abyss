generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Consultation {
  id                String   @id @default(uuid())
  fullName          String
  email             String
  phone             String?
  consultationType  String   // 'obstetrics' | 'gynaecology' | 'fertility'
  message           String?
  status            String   @default("pending") // 'pending' | 'contacted' | 'completed' | 'cancelled'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("consultations")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // hashed
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("admins")
}
