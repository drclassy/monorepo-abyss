# Force LF for all shell scripts and entrypoints (Linux containers can't exec CRLF).
*.sh              text eol=lf
docker-entrypoint text eol=lf
start-all         text eol=lf
entrypoint        text eol=lf
Dockerfile        text eol=lf
*.Dockerfile      text eol=lf

# Force LF for everything inside vendored submodules (Linux container builds)
vendor/**         text eol=lf
