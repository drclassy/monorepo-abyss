# Hermes Maximus — Environment Template
# Copy to .env and fill in. .env is gitignored.

# ─────────────────────────────────────────────────────────────
# PRIMARY LLM PROVIDER (pick ONE minimum)
# ─────────────────────────────────────────────────────────────
# Nous Research (original Hermes provider)
NOUS_API_KEY=

# Anthropic Claude (also accepted by hermes-core; required by workspace-ui default config)
ANTHROPIC_API_KEY=

# OpenAI (required by hindsight default LLM provider)
OPENAI_API_KEY=

# Google Vertex AI / GCP (Chief's primary cloud) — optional
GCP_PROJECT=
VERTEX_LOCATION=us-central1

# Local model endpoint — optional (Ollama / LM Studio / vLLM)
# CUSTOM_BASE_URL=http://host.docker.internal:11434/v1

# ─────────────────────────────────────────────────────────────
# HERMES-CORE (gateway mode)
# ─────────────────────────────────────────────────────────────
# Enable HTTP API server (required to expose port 8642)
API_SERVER_ENABLED=true
API_SERVER_PORT=8642

# ─────────────────────────────────────────────────────────────
# HINDSIGHT (memory backend)
# ─────────────────────────────────────────────────────────────
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_HOST=0.0.0.0
HINDSIGHT_API_PORT=8888
HINDSIGHT_ENABLE_API=true
HINDSIGHT_ENABLE_CP=true

# ─────────────────────────────────────────────────────────────
# MISSION CONTROL
# ─────────────────────────────────────────────────────────────
MC_PORT=3000
MC_DEFAULT_GATEWAY_NAME=primary
MC_ALLOWED_HOSTS=localhost,127.0.0.1
# First-run seed (optional — otherwise visit /setup on first boot)
# AUTH_USER=admin
# AUTH_PASS=change-me-please

# ─────────────────────────────────────────────────────────────
# WORKSPACE UI
# ─────────────────────────────────────────────────────────────
WORKSPACE_UI_PORT=3001
HERMES_API_URL=http://hermes-core:8642

# ─────────────────────────────────────────────────────────────
# PLUGINS — Phase 2 (web-search-plus)
# ─────────────────────────────────────────────────────────────
SERPER_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# ─────────────────────────────────────────────────────────────
# NETWORKING
# ─────────────────────────────────────────────────────────────
# Bind all ports to localhost only (NEVER change unless you know why)
HERMES_BIND=127.0.0.1
