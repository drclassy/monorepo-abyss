{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "LANGFLOW_API_URL",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "AVVCENNA_PLUS_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL", "LANGFLOW_API_URL"],
      "cache": true
    },
    "@the-abyss/orchestrator#build": {
      "dependsOn": ["@the-abyss/database#prisma:generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": ["DATABASE_URL", "LANGFLOW_API_URL"],
      "cache": true
    },
    "@the-abyss/database#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "prisma/schema.prisma"],
      "outputs": [],
      "cache": false
    },
    "prisma:generate": {
      "cache": false,
      "inputs": ["prisma/schema.prisma"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.test.ts", "src/**/*.test.tsx"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:ui": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": []
    },
    "db:generate": {
      "cache": false,
      "inputs": ["prisma/schema.prisma"]
    },
    "db:push": {
      "cache": false,
      "inputs": ["prisma/schema.prisma"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "flows:test": {
      "dependsOn": ["build"],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "//#typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    }
  }
}
