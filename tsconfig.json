{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "paths": {
      "*": ["./*"],
      "@the-abyss/*": ["./packages/*/src"],
      "@the-abyss/sentra-ui": ["./packages/sentra-ui/src"],
      "@the-abyss/database": ["./packages/database/src"],
      "@the-abyss/langflow-client": ["./packages/langflow-client/src"],
      "@sentra/sandi": ["./packages/sentra-sandi/src"],
      "@sentra/cermin": ["./packages/sentra-cermin/src"],
      "@the-abyss/shared-types": ["./packages/shared-types/src"],
      "@sentra/bentara": ["./packages/sentra-bentara/src"],
       "@the-abyss/literature-harvester": ["./packages/literature-harvester/src"]
    },
    "types": ["node"]
  },
  "include": ["packages/**/src/**/*", "tooling/**/src/**/*"],
  "exclude": ["node_modules", "dist", "build", ".next", "coverage"]
}
