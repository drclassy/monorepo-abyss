{
  "id": "referral-flow-v1",
  "name": "Patient Referral Flow",
  "description": "AI-assisted patient referral routing — validates FHIR data, AI triage scoring, routes to appropriate specialist or facility",
  "version": "1.0.0",
  "domain": "healthcare",
  "compliance": ["PHI", "FHIR-R4"],
  "trigger": "manual",
  "nodes": [
    {
      "id": "input-referral",
      "type": "InputNode",
      "label": "Referral Request Input",
      "schema": "fhir:ServiceRequest"
    },
    {
      "id": "phi-gate",
      "type": "GuardNode",
      "label": "PHI Sanitization Gate",
      "config": {
        "strip_fields": ["patient.name", "patient.birthDate", "patient.identifier"],
        "log_access": true
      }
    },
    {
      "id": "fhir-validator",
      "type": "TransformNode",
      "label": "FHIR R4 Validator",
      "package": "@the-abyss/fhir-engine",
      "method": "validateServiceRequest"
    },
    {
      "id": "ai-triage",
      "type": "AINode",
      "label": "AI Triage Scoring",
      "model": "claude-sonnet-4-6",
      "prompt_template": "triage-score-v2",
      "output_schema": {
        "urgency": "low | medium | high | critical",
        "specialty": "string",
        "reasoning": "string"
      }
    },
    {
      "id": "route-decision",
      "type": "DecisionNode",
      "label": "Routing Decision",
      "rules": [
        { "if": "urgency == critical", "then": "route-emergency" },
        { "if": "urgency == high", "then": "route-specialist" },
        { "default": "route-standard" }
      ]
    },
    {
      "id": "route-emergency",
      "type": "OutputNode",
      "label": "Emergency Routing",
      "action": "notify:on-call-team"
    },
    {
      "id": "route-specialist",
      "type": "OutputNode",
      "label": "Specialist Routing",
      "action": "create:specialist-appointment"
    },
    {
      "id": "route-standard",
      "type": "OutputNode",
      "label": "Standard Queue Routing",
      "action": "create:referral-queue-entry"
    }
  ],
  "edges": [
    { "source": "input-referral", "target": "phi-gate" },
    { "source": "phi-gate", "target": "fhir-validator" },
    { "source": "fhir-validator", "target": "ai-triage" },
    { "source": "ai-triage", "target": "route-decision" },
    { "source": "route-decision", "target": "route-emergency" },
    { "source": "route-decision", "target": "route-specialist" },
    { "source": "route-decision", "target": "route-standard" }
  ],
  "metadata": {
    "author": "Dr. Ferdi Iskandar (Classy)",
    "created_at": "2026-04-19",
    "last_updated": "2026-04-19",
    "langflow_compatible": true
  }
}
