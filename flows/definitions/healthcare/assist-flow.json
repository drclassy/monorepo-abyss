{
  "id": "sentra-assist-flow-v1",
  "name": "Sentra AI Assistant Flow",
  "description": "Clinical AI assistant conversation flow — handles patient queries, symptom checker, medication reminders with full PHI compliance",
  "version": "1.0.0",
  "domain": "healthcare",
  "compliance": ["PHI", "FHIR-R4"],
  "trigger": "api",
  "nodes": [
    {
      "id": "user-input",
      "type": "InputNode",
      "label": "User Message Input",
      "schema": "ChatMessage"
    },
    {
      "id": "phi-gate",
      "type": "GuardNode",
      "label": "PHI Detection Gate",
      "config": {
        "detect_phi": true,
        "mask_before_log": true
      }
    },
    {
      "id": "intent-classifier",
      "type": "AINode",
      "label": "Intent Classifier",
      "model": "claude-haiku-4-5-20251001",
      "prompt_template": "intent-classify-v1",
      "output_schema": {
        "intent": "symptom_check | medication | appointment | general | escalate",
        "confidence": "number"
      }
    },
    {
      "id": "memory-fetch",
      "type": "VectorNode",
      "label": "Conversation Memory Fetch",
      "package": "@the-abyss/vector-store",
      "method": "getRelevantContext"
    },
    {
      "id": "clinical-response",
      "type": "AINode",
      "label": "Clinical Response Generation",
      "model": "claude-sonnet-4-6",
      "prompt_template": "clinical-assistant-v3",
      "system_prompt": "You are Jen, Sentra AI's clinical assistant. Always recommend consulting a doctor for diagnosis. Never provide definitive medical diagnoses."
    },
    {
      "id": "escalation-check",
      "type": "DecisionNode",
      "label": "Escalation Decision",
      "rules": [
        { "if": "intent == escalate", "then": "human-handoff" },
        { "default": "output-response" }
      ]
    },
    {
      "id": "human-handoff",
      "type": "OutputNode",
      "label": "Human Handoff",
      "action": "notify:on-call-clinician"
    },
    {
      "id": "output-response",
      "type": "OutputNode",
      "label": "Response Output",
      "action": "stream:chat-response"
    }
  ],
  "edges": [
    { "source": "user-input", "target": "phi-gate" },
    { "source": "phi-gate", "target": "intent-classifier" },
    { "source": "intent-classifier", "target": "memory-fetch" },
    { "source": "memory-fetch", "target": "clinical-response" },
    { "source": "clinical-response", "target": "escalation-check" },
    { "source": "escalation-check", "target": "human-handoff" },
    { "source": "escalation-check", "target": "output-response" }
  ],
  "metadata": {
    "author": "Dr. Ferdi Iskandar (Classy)",
    "created_at": "2026-04-19",
    "last_updated": "2026-04-19",
    "langflow_compatible": true
  }
}
