{
  "name": "the-abyss",
  "version": "0.0.1",
  "private": true,
  "description": "AI-Native Monorepo for Sentra AI Ecosystem",
  "author": "Dr. Ferdi Iskandar (Classy) <drferdiiskandar@sentrahai.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build --filter=!@the-abyss/orchestrator",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=!@the-abyss/orchestrator",
    "test:ui": "turbo run test:ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "typecheck": "pnpm --filter @the-abyss/database prisma:generate && tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules",
    "graph": "turbo run build --graph=dependency-graph.png",
    "abyss": "pnpm --filter @the-abyss/cli",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "pnpm --filter @the-abyss/database db:studio",
    "flows:test": "turbo run flows:test",
    "governance:agents-check": "node tooling/governance/agent/healthcheck.js",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:tag": "changeset tag"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "//hoisting-workaround": "baseline-browser-mapping, caniuse-lite, picocolors are pinned at root to ensure pnpm hoists them into root node_modules so the tailwindcss CLI (used by @the-abyss/ui#build) and browserslist toolchain can resolve them via parent traversal. Removing them breaks @the-abyss/ui build with 'Cannot find module picocolors'. See VERIFICATION-REPORT for context.",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.5",
    "@the-abyss/config-eslint": "workspace:*",
    "@types/node": "22.19.19",
    "baseline-browser-mapping": "^2.10.24",
    "caniuse-lite": "1.0.30001788",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "15.5.2",
    "picocolors": "1.1.1",
    "prettier": "3.8.3",
    "turbo": "2.9.12",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@>=10.0.0 <10.2.3": "10.2.5",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "esbuild@<0.25.0": "0.25.12",
      "markdown-it@<14.1.1": "14.1.1",
      "ajv@>=6.0.0 <6.14.0": "6.14.0",
      "tmp@<0.2.6": "0.2.6",
      "path-to-regexp@>=4.0.0 <6.3.0": "6.3.0",
      "tar@<7.5.11": "7.5.11",
      "undici@<6.24.0": "6.24.0",
      "vite": "6.4.2",
      "effect": "3.20.0",
      "xlsx": "npm:@e965/xlsx@0.20.3"
    }
  }
}
