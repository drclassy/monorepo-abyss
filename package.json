{
  "name": "the-abyss",
  "version": "0.0.1",
  "private": true,
  "description": "AI-Native Monorepo for Sentra AI Ecosystem",
  "author": "Dr. Ferdi Iskandar (Classy) <ferdi@sentra.ai>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ui": "turbo run test:ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules",
    "graph": "turbo run build --graph=dependency-graph.png",
    "abyss": "pnpm --filter @the-abyss/cli",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "pnpm --filter @the-abyss/database db:studio",
    "flows:test": "turbo run flows:test",
    "security:primary-healthcare": "pnpm --filter @the-abyss/sentra-dashboard run security:catch-scan && pnpm --filter @the-abyss/sentra-dashboard run security:secret-scan && pnpm --filter @the-abyss/puskesmas-website run security:catch-scan && pnpm --filter @the-abyss/puskesmas-website run security:secret-scan && pnpm --filter @the-abyss/sentra-dashboard run security:audit && pnpm --filter @the-abyss/puskesmas-website run security:audit",
    "governance:agents-check": "node tooling/scripts/governance/agents-healthcheck.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "eslint": "9.39.4",
    "lint-staged": "15.5.2",
    "prettier": "3.8.3",
    "turbo": "2.9.12",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "esbuild@<0.25.0": "0.25.12",
      "markdown-it@<14.1.1": "14.1.1",
      "ajv@>=6.0.0 <6.14.0": "6.14.0",
      "vite": "6.4.2",
      "effect": "3.20.0",
      "xlsx": "npm:@e965/xlsx@0.20.3"
    }
  },
  "workspaces": [
    "packages/*",
    "tooling/*"
  ]
}
