{
  "name": "the-abyss",
  "version": "0.0.1",
  "private": true,
  "description": "AI-Native Monorepo for Sentra AI Ecosystem",
  "author": "Dr. Ferdi Iskandar (Claudesy) <ferdi@sentra.ai>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ui": "turbo run test:ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules",
    "graph": "turbo run build --graph=dependency-graph.png",
    "abyss": "pnpm --filter @the-abyss/cli",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "pnpm --filter @the-abyss/database db:studio",
    "flows:test": "turbo run flows:test"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/**",
    "packages/*",
    "tooling/*"
  ]
}
