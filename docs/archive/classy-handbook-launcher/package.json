{
  "name": "classy-handbook-launcher",
  "displayName": "Classy Handbook Launcher",
  "description": "Open Sentra handbook HTML documents from the command palette and status bar.",
  "version": "1.0.0",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "classyHandbook.openDocument",
        "title": "Classy Handbook: Open Document",
        "category": "Classy Handbook"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
