{
  "name": "@the-abyss/orchestrator",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "pnpm -w --filter @the-abyss/database prisma:generate && tsc",
