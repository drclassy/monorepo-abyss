    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.18",
    "@the-abyss/database": "workspace:*",
    "@the-abyss/langflow-client": "workspace:*",
    "@the-abyss/shared-types": "workspace:*",
    "@sentra/nada": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.19",
    "@the-abyss/config-eslint": "workspace:*",
    "@the-abyss/config-typescript": "workspace:*",
    "@types/node": "22.19.19",
    "@types/supertest": "6.0.3",
    "supertest": "7.2.2",
