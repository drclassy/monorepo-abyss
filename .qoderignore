# .qoderignore
# Files and directories Qoder must NOT index, embed, or include in context.
# This is a hard boundary — treat it as security-critical.

# ============================================================
# PHI / Patient data — NEVER let the AI agent see these
# ============================================================
patient-data/
phi/
clinical-data/raw/
clinical-data/identifiable/
**/patient_*.csv
**/patient_*.json
**/patient_*.parquet
**/phi_*
**/*_phi.*
**/*_identifiable.*
**/medical_records/

# ============================================================
# Secrets and credentials
# ============================================================
.env
.env.*
!.env.example
**/secrets/
**/credentials/
*.pem
*.key
*.p12
*.pfx
*_secret.*
*_token.*
.npmrc
.pypirc

# ============================================================
# Build artifacts and caches (irrelevant for AI context)
# ============================================================
node_modules/
.pnpm-store/
.yarn/cache/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
venv/
env/
.uv/
dist/
build/
*.egg-info/
.next/
out/
target/
.turbo/
.cache/

# ============================================================
# Logs and runtime data
# ============================================================
*.log
logs/
.terraform/
terraform.tfstate*
*.tfvars
!*.tfvars.example

# ============================================================
# Large binaries and ML artifacts (waste context)
# ============================================================
*.pt
*.pth
*.onnx
*.gguf
*.safetensors
*.bin
models/checkpoints/
data/embeddings/
data/raw/
data/processed/large/
*.zip
*.tar
*.tar.gz
*.7z

# ============================================================
# IDE and editor noise
# ============================================================
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# Internal-only docs (sensitive business info)
# ============================================================
docs/internal/legal/
docs/internal/finance/
docs/internal/contracts/
investor-decks/

# ============================================================
# Prototypes — index lightly (do not exclude entirely)
# Comment the next line if you want prototypes indexed:
# prototypes/
